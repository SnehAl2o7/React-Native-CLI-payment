# ============================================================================
# Environment Configuration — Example Template
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ============================================================================

# Server port — the port Express will listen on
PORT=5000

# MongoDB connection URI — replace with your MongoDB Atlas or local connection string
# The ?replicaSet=rs0 flag enables transaction support (required for ACID operations)
MONGO_URI=mongodb://127.0.0.1:27017/your_database_name?replicaSet=rs0

# JWT secret — used to sign and verify JSON Web Tokens for authentication
# Generate a strong random string for production use
JWT_SECRET=your_jwt_secret_here

# AES-256 Encryption Key — MUST be exactly 64 hex characters (32 bytes)
# Used for field-level encryption of sensitive payment data
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_hex_character_encryption_key_here_replace_me_now_please
